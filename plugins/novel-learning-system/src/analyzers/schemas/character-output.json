{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CharacterAnalysisOutput",
  "description": "人物设计分析输出 Schema",
  "type": "object",
  "required": ["appearances"],
  "properties": {
    "appearances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "is_new", "actions"],
        "properties": {
          "name": { "type": "string" },
          "is_new": { "type": "boolean" },
          "actions": { "type": "string" },
          "dialogue_count": { "type": "integer", "minimum": 0 },
          "emotional_state": { "type": "string" },
          "status_change": { "type": ["string", "null"] }
        }
      }
    },
    "new_characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role_type"],
        "properties": {
          "name": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "role_type": { "type": "string", "enum": ["protagonist", "antagonist", "supporting", "minor", "mentioned"] },
          "gender": { "type": "string" },
          "personality_tags": { "type": "array", "items": { "type": "string" } },
          "motivation": { "type": ["string", "null"] },
          "power_level": { "type": ["string", "null"] },
          "faction": { "type": ["string", "null"] },
          "speech_patterns": { "type": "object" },
          "dialogue_samples": { "type": "array", "items": { "type": "string" }, "maxItems": 3 }
        }
      }
    },
    "relationship_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["character_a", "character_b", "relationship_type"],
        "properties": {
          "character_a": { "type": "string" },
          "character_b": { "type": "string" },
          "relationship_type": { "type": "string", "enum": ["ally", "enemy", "lover", "master-disciple", "family", "rival", "friend"] },
          "description": { "type": "string" },
          "is_new": { "type": "boolean" }
        }
      }
    }
  }
}
